#!/bin/sh
# Auto-bump de la versión de la app en config.js antes de cada commit.
# Esquema: major.minor, el minor va 0..9 y al llegar a 10 hace rollover al major.
#   1.8 -> 1.9 -> 2.0 -> 2.1 -> ... -> 2.9 -> 3.0
# El config.js modificado se re-agrega al commit en curso.

CONFIG="config.js"
[ -f "$CONFIG" ] || exit 0

cur=$(grep -oE "VERSION:[[:space:]]*'[0-9]+\.[0-9]+'" "$CONFIG" | grep -oE "[0-9]+\.[0-9]+" | head -n 1)
[ -n "$cur" ] || exit 0

major=${cur%.*}
minor=${cur#*.}
minor=$((minor + 1))
if [ "$minor" -ge 10 ]; then
    minor=0
    major=$((major + 1))
fi
new="$major.$minor"

# Reemplaza la línea VERSION conservando el formato. Usa un delimitador alterno por las comillas.
sed -i "s/VERSION:[[:space:]]*'[0-9][0-9]*\.[0-9][0-9]*'/VERSION: '$new'/" "$CONFIG"

git add "$CONFIG"
echo "[pre-commit] Versión de la app: $cur -> $new"
